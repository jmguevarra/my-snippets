        "jsCode": "let brand = $input.first().json.query?.brand; \nlet graphqlQuery;\n\nif (brand) {\n  // Option A: Filtering by brand name\n  graphqlQuery = `{ \n    boards(ids: 8707940198) { \n      items_page(limit: 200, query_params: { \n        rules: [{ \n          column_id: \"name\", \n          compare_value: [\"${brand}\"], \n          operator: contains_text \n        }] \n      }) { \n        items { \n          id \n          name \n          state \n          column_values(ids: [\"boolean_mm16wr1g\", \"boolean_mm16vrs2\"]) { \n            id \n            text \n            value \n          } \n        } \n      } \n    } \n  }`;\n} else {\n  // Option B: No filter\n  graphqlQuery = `{ \n    boards(ids: 8707940198) { \n      items_page(limit: 200) { \n        items { \n          id \n          name \n          state \n          column_values(ids: [\"boolean_mm16wr1g\", \"boolean_mm16vrs2\"]) { \n            id \n            text \n            value \n          } \n        } \n      } \n    } \n  }`;\n}\n\n// Wrap it in the expected Monday.com JSON structure\nreturn [{ \n  json: { \n    queryBody: { query: graphqlQuery } \n  } \n}];"
