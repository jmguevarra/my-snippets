    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst inputAuthDns = $('Merge Auth and DNS Data').first().json;\nconst allItems = JSON.parse(input.allItems || '[]');\nconst productLines = inputAuthDns.authProductLines || [];\n\nconst productLineIds = productLines.map(pl => pl.id);\nconst productLineNames = productLines.map(pl => pl.name);\n\nfunction colText(item, colId) {\n  const col = (item.column_values || []).find(c => c.id === colId);\n  return col ? (col.text || '') : '';\n}\n\nfunction colLinkedItems(item, colId) {\n  const col = (item.column_values || []).find(c => c.id === colId);\n  return col && col.linked_items ? col.linked_items : [];\n}\n\nfunction baseDnsRow(item, isStatusColumn = false) {\n  const longText = colText(item, 'long_text_mkp5n4a0').replace(/[\\r\\n]+/g, ' ');\n  const name1 = colText(item, 'text_mkp5a2bm');\n  const name2 = colText(item, 'text_mkp5cd5a');\n  const statusOrColor = isStatusColumn ? 'status' : 'color_mkrb6wej';\n  \n  return [\n    colText(item, statusOrColor),\n    colText(item, 'date4'),\n    colText(item, 'text_mkp51hj6'),\n    colText(item, 'text_mkp5gejv'),\n    longText,\n    (name1 + ' ' + name2).trim(),\n    colText(item, 'email_mkp59dnc'),\n    colText(item, 'text_mkq7zecr'),\n    colText(item, 'link_mkp52229')\n  ];\n}\n\nconst dnsNewHighlightRows = [];\nconst dnsDeniedRows = [];\nconst authApprovedRows = [];\nconst approvedStatuses = [\n  \"Approved for B&M\",\n  \"Approved for B&M + Ecom\",\n  \"Approved for Ecom\",\n  \"CA B&M + Ecom\",\n  \"CA B&M Only\",\n  \"Direct Customer\",\n  \"Limited Agreement\"\n];\n\nfor (const item of allItems) {\n  const groupText = item?.group?.title?.trim().toLowerCase() ?? '';\n  const status = colText(item, 'status');\n  const appStatus = colText(item, 'color_mkrb6wej');\n  const isNotArchived = groupText !== 'archived';\n\n  if ((status.includes('Highlight Denied') || status.includes('New Denied')) && isNotArchived) {\n    dnsNewHighlightRows.push(baseDnsRow(item, true));\n  }\n\n  if (appStatus === 'Denied' && isNotArchived) {\n    dnsDeniedRows.push(baseDnsRow(item));\n  }\n\n  if (approvedStatuses.some(s => appStatus.includes(s) && isNotArchived)){\n    const baseRow = baseDnsRow(item);\n    const agreementStatus = colText(item, 'status');\n    const agreementSigned = agreementStatus.includes('Agreement Signed') ? 'x' : '';\n    const linkedItems = colLinkedItems(item, 'board_relation_mkrqc6jm');\n    const linkedIds = linkedItems.map(li => String(li.id));\n    const productCols = productLineIds.map(plId =>\n      linkedIds.includes(String(plId)) ? 'x' : ''\n    );\n    authApprovedRows.push([...baseRow, agreementSigned, ...productCols]);\n  }\n}\n\n\n//sorting\nconst sortedDNSNewHighlightItems = dnsNewHighlightRows\n  .sort((a, b) => {\n    // Priority: Highlight Denied first\n    const priority = (item) => item[0].includes(\"Highlight Denied\") ? 0 : 1;\n    const priorityDiff = priority(a) - priority(b);\n    if (priorityDiff !== 0) return priorityDiff;\n\n    // If same priority, sort by 3rd column alphabetically\n    return a[2].localeCompare(b[2]);\n  })\n  .map((item) => {\n    // Copy the row to avoid mutating original\n    const newRow = [...item];\n\n    // Ensure phone column (H column, index 7) is a string\n    if (newRow[7] != null) {\n      const phoneStr = newRow[7].toString().trim();\n      newRow[7] = phoneStr.startsWith(\"+\") ? `'${phoneStr}` : phoneStr;\n    }\n\n    // Remove \"Denied\" from first column and trim spaces\n    newRow[0] = newRow[0].replace(\"Denied\", \"\").trim();\n\n    return newRow;\n  });\n\nconst priorityMap = {\n  \"Approved for B&M\": 0,\n  \"Approved for B&M + Ecom\": 1,\n  \"Approved for Ecom\": 2,\n  \"CA B&M + Ecom\": 3,\n  \"CA B&M Only\": 4,\n  \"Direct Customer\": 5,\n  \"Limited Agreement\": 6\n};\n\nconst sortedAuthApprovedRowsItems = authApprovedRows\n  .map(row => {\n    const newRow = [...row]; \n    if (newRow[7] != null) {\n      const phoneStr = newRow[7].toString().trim();\n      newRow[7] = phoneStr.startsWith(\"+\") ? `'${phoneStr}` : phoneStr;\n    }\n    return newRow;\n  })\n  .sort((a, b) => {\n  // First, sort by priority\n  const priorityDiff = priorityMap[a[0]] - priorityMap[b[0]];\n  if (priorityDiff !== 0) return priorityDiff;\n\n  // If priority is the same, sort by 3rd item alphabetically\n  return a[2].localeCompare(b[2]);\n});\n\nconst sortedDNSDeniedRows = dnsDeniedRows\n  .map(row => {\n    const newRow = [...row]; \n    if (newRow[7] != null) {\n      const phoneStr = newRow[7].toString().trim();\n      newRow[7] = phoneStr.startsWith(\"+\") ? `'${phoneStr}` : phoneStr;\n    }\n    return newRow;\n  })\n  .sort((a, b) => {\n    return a[2].localeCompare(b[2]);\n});\nconst dnsDeniedWithHeader = sortedDNSDeniedRows.length > 0\n  ? [[\"\", \"\", \"\"], [\"Below is the full DNS List\", \"\", \"\"], ...sortedDNSDeniedRows]\n  : [];\n\n \nreturn [{\n  json: {\n    dnsSheetId: inputAuthDns.dnsSheetId,\n    authSheetId: inputAuthDns.authSheetId,\n    brandId: inputAuthDns.brandId,\n    brandName: inputAuthDns.brandName,\n    dnsNewHighlightRows: JSON.stringify(sortedDNSNewHighlightItems),\n    dnsDeniedWithHeader: JSON.stringify(dnsDeniedWithHeader),\n    authApprovedRows: JSON.stringify(sortedAuthApprovedRowsItems),\n    productLineNames: JSON.stringify(productLineNames),\n    hasDnsNewHighlight: dnsNewHighlightRows.length > 0,\n    hasDnsDenied: dnsDeniedRows.length > 0,\n    hasAuthApproved: authApprovedRows.length > 0,\n    hasProductLines: productLines.length > 0\n  }\n}];"
      },
